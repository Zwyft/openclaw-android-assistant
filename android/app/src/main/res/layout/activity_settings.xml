<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617"
    android:fillViewport="true"
    tools:context=".SettingsActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- ============================================ -->
        <!-- Section: API Keys                            -->
        <!-- ============================================ -->
        <TextView
            android:id="@+id/sectionApiKeysTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_api_keys"
            android:textColor="#818cf8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- OpenAI Key Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOpenAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#1e1b4b"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/sectionApiKeysTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="#312e81"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/labelOpenAI"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/openai_key_label"
                    android:textColor="#f1f5f9"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/descOpenAI"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/openai_key_desc"
                    android:textColor="#94a3b8"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelOpenAI" />

                <TextView
                    android:id="@+id/statusOpenAI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/key_not_set"
                    android:textColor="#f87171"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/descOpenAI" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutOpenAI"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/api_key_placeholder"
                    app:boxBackgroundColor="#0f172a"
                    app:boxStrokeColor="#6366f1"
                    app:hintTextColor="#94a3b8"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/statusOpenAI"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputOpenAIKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="#f1f5f9"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/btnRowOpenAI"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    app:layout_constraintTop_toBottomOf="@id/inputLayoutOpenAI"
                    app:layout_constraintStart_toStartOf="parent">

                    <Button
                        android:id="@+id/btnSaveOpenAI"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#6366f1"
                        android:text="@string/save"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.Tonal" />

                    <Button
                        android:id="@+id/btnClearOpenAI"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#dc2626"
                        android:text="@string/clear"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.Tonal" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- OpenRouter Key Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOpenRouter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#1e1b4b"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardOpenAI"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="#312e81"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/labelOpenRouter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/openrouter_key_label"
                    android:textColor="#f1f5f9"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/descOpenRouter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/openrouter_key_desc"
                    android:textColor="#94a3b8"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelOpenRouter" />

                <TextView
                    android:id="@+id/statusOpenRouter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/key_not_set"
                    android:textColor="#f87171"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/descOpenRouter" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutOpenRouter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/api_key_placeholder"
                    app:boxBackgroundColor="#0f172a"
                    app:boxStrokeColor="#6366f1"
                    app:hintTextColor="#94a3b8"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/statusOpenRouter"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputOpenRouterKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="#f1f5f9"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/btnRowOpenRouter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    app:layout_constraintTop_toBottomOf="@id/inputLayoutOpenRouter"
                    app:layout_constraintStart_toStartOf="parent">

                    <Button
                        android:id="@+id/btnSaveOpenRouter"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#6366f1"
                        android:text="@string/save"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.Tonal" />

                    <Button
                        android:id="@+id/btnClearOpenRouter"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#dc2626"
                        android:text="@string/clear"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.Tonal" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- OpenCode Key Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOpenCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#1e1b4b"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardOpenRouter"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="#312e81"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/labelOpenCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/opencode_key_label"
                    android:textColor="#f1f5f9"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/descOpenCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/opencode_key_desc"
                    android:textColor="#94a3b8"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelOpenCode" />

                <TextView
                    android:id="@+id/statusOpenCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/key_not_set"
                    android:textColor="#f87171"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/descOpenCode" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutOpenCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/api_key_placeholder"
                    app:boxBackgroundColor="#0f172a"
                    app:boxStrokeColor="#6366f1"
                    app:hintTextColor="#94a3b8"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/statusOpenCode"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputOpenCodeKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="#f1f5f9"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/btnRowOpenCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    app:layout_constraintTop_toBottomOf="@id/inputLayoutOpenCode"
                    app:layout_constraintStart_toStartOf="parent">

                    <Button
                        android:id="@+id/btnSaveOpenCode"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#6366f1"
                        android:text="@string/save"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.Tonal" />

                    <Button
                        android:id="@+id/btnClearOpenCode"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#dc2626"
                        android:text="@string/clear"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.Tonal" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============================================ -->
        <!-- Section: Server Status                       -->
        <!-- ============================================ -->
        <TextView
            android:id="@+id/sectionServerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_server"
            android:textColor="#818cf8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardOpenCode" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#1e1b4b"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/sectionServerTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="#312e81"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/labelServerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/server_status_checking"
                    android:textColor="#f1f5f9"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/serverStatusDot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/circle_gray"
                    android:layout_marginTop="3dp"
                    app:layout_constraintStart_toEndOf="@id/labelServerStatus"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/labelServerPort"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/server_port_label"
                    android:textColor="#94a3b8"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelServerStatus" />

                <TextView
                    android:id="@+id/serverPortValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="6dp"
                    android:text="18923"
                    android:textColor="#f1f5f9"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/labelServerPort"
                    app:layout_constraintTop_toBottomOf="@id/labelServerStatus" />

                <LinearLayout
                    android:id="@+id/btnRowServer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    app:layout_constraintTop_toBottomOf="@id/labelServerPort"
                    app:layout_constraintStart_toStartOf="parent">

                    <Button
                        android:id="@+id/btnStartServer"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#22c55e"
                        android:text="@string/server_start"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.Tonal" />

                    <Button
                        android:id="@+id/btnStopServer"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:backgroundTint="#ef4444"
                        android:text="@string/server_stop"
                        android:textColor="#ffffff"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.Tonal" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============================================ -->
        <!-- Section: Environment                         -->
        <!-- ============================================ -->
        <TextView
            android:id="@+id/sectionEnvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_environment"
            android:textColor="#818cf8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardServer" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEnv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#1e1b4b"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/sectionEnvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="#312e81"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/envBootstrapLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/env_bootstrap"
                    android:textColor="#f1f5f9"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/envBootstrapStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/env_bootstrap_not_installed"
                    android:textColor="#f87171"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/envNodeLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/env_nodejs"
                    android:textColor="#f1f5f9"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/envBootstrapLabel" />

                <TextView
                    android:id="@+id/envNodeStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/env_not_available"
                    android:textColor="#94a3b8"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/envBootstrapStatus" />

                <TextView
                    android:id="@+id/envPythonLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/env_python"
                    android:textColor="#f1f5f9"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/envNodeLabel" />

                <TextView
                    android:id="@+id/envPythonStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/env_not_available"
                    android:textColor="#94a3b8"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/envNodeStatus" />

                <TextView
                    android:id="@+id/envCodexLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/env_codex"
                    android:textColor="#f1f5f9"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/envPythonLabel" />

                <TextView
                    android:id="@+id/envCodexStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/env_not_available"
                    android:textColor="#94a3b8"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/envPythonStatus" />

                <Button
                    android:id="@+id/btnReinstallEnv"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#f59e0b"
                    android:text="@string/env_reinstall"
                    android:textColor="#ffffff"
                    android:textSize="13sp"
                    style="@style/Widget.Material3.Button.Tonal"
                    app:layout_constraintTop_toBottomOf="@id/envCodexLabel"
                    app:layout_constraintStart_toStartOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============================================ -->
        <!-- Section: About                              -->
        <!-- ============================================ -->
        <TextView
            android:id="@+id/sectionAboutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_about"
            android:textColor="#818cf8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardEnv" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1e1b4b"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/sectionAboutTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="#312e81"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/aboutAppName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="#f1f5f9"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/aboutAgents"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/about_agents"
                    android:textColor="#94a3b8"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/aboutAppName" />

                <TextView
                    android:id="@+id/aboutVersion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/about_version"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/aboutAgents" />

                <TextView
                    android:id="@+id/aboutVersionValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
